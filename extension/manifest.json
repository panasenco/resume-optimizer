{
    "manifest_version": 2,
    "name": "Resume Optimizer",
    "version": "0.0.0-alpha",
    "description": "Generates the optimal version of your resume for a particular job posting.",
    "icons": {
        "32": "icons/leftpad-32.png"
    },
    "browser_action": {
        "default_icon": "icons/leftpad-32.png",
        "default_title": "Resume Optimizer",
        "default_popup": "popup/index.html",
        "browser_style": true
    },
    "background": {
        "scripts": ["background/index.js"]
    },
    "content_scripts": [{
        "matches": ["https://www.indeed.com/*"],
        "js": ["content/index.js"]
    }]
}
